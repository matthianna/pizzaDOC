# ===========================================
# SVILUPPO LOCALE (SQLite)
# ===========================================
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# ===========================================
# PRODUZIONE VERCEL (PostgreSQL - Neon)
# ===========================================
# Usa questi valori su Vercel Dashboard → Settings → Environment Variables
# 
# DATABASE_URL con Neon PostgreSQL (usa connessione POOLED):
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
#
# NEXTAUTH_URL (il tuo dominio Vercel):
# NEXTAUTH_URL="https://your-app.vercel.app"
#
# NEXTAUTH_SECRET (genera con: openssl rand -base64 32):
# NEXTAUTH_SECRET="generate-a-secure-secret"
#
# ⚠️ IMPORTANTE: 
# - Usa la connessione POOLED (con -pooler nell'URL) per Vercel
# - Includi sempre sslmode=require per Neon
# - Non committare mai il file .env con credenziali reali

# ===========================================
# CRON JOB SECURITY (Opzionale)
# ===========================================
# CRON_SECRET (su Vercel è obbligatorio per chiamate fuori dallo scheduler se non passi da x-vercel-cron)
# CRON_SECRET="your-cron-secret-token"
#
# SEED_SECRET (obbligatorio in produzione / su Vercel per POST /api/seed):
# openssl rand -base64 32
# SEED_SECRET="..."
#
# Chiamata seed protetta:
# curl -X POST -H "Authorization: Bearer $SEED_SECRET" https://your-app.vercel.app/api/seed

# ===========================================
# RATE LIMIT LOGIN (Upstash Redis — consigliato in produzione)
# ===========================================
# Senza queste variabili si usa un limitatore in-memory nel middleware Edge (meno efficace su più istanze).
# Crea database Redis gratuito: https://upstash.com
#
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."
